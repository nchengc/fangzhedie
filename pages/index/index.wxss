.container {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  background: linear-gradient(-45deg, #0a0a1a 0%, #0f1a2e 25%, #1a2744 50%, #0f1a2e 75%, #0a0a1a 100%);
  background-size: 400% 400%;
  animation: gradientFlow 12s ease infinite;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  position: relative;
  overflow: hidden;
}

@keyframes gradientFlow {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(2.5rpx 2.5rpx at 60rpx 90rpx, rgba(255,255,255,0.95), transparent),
    radial-gradient(1.5rpx 1.5rpx at 180rpx 250rpx, rgba(255,255,255,0.7), transparent),
    radial-gradient(2rpx 2rpx at 320rpx 150rpx, rgba(255,255,255,0.85), transparent),
    radial-gradient(1rpx 1rpx at 450rpx 380rpx, rgba(255,255,255,0.6), transparent),
    radial-gradient(2.5rpx 2.5rpx at 90rpx 520rpx, rgba(255,255,255,0.9), transparent),
    radial-gradient(1rpx 1rpx at 280rpx 600rpx, rgba(255,255,255,0.65), transparent),
    radial-gradient(2rpx 2rpx at 500rpx 200rpx, rgba(255,255,255,0.8), transparent),
    radial-gradient(1.5rpx 1.5rpx at 200rpx 720rpx, rgba(255,255,255,0.75), transparent),
    radial-gradient(2rpx 2rpx at 380rpx 820rpx, rgba(255,255,255,0.9), transparent),
    radial-gradient(1rpx 1rpx at 60rpx 950rpx, rgba(255,255,255,0.55), transparent),
    radial-gradient(2.5rpx 2.5rpx at 160rpx 1100rpx, rgba(255,255,255,0.85), transparent),
    radial-gradient(1rpx 1rpx at 420rpx 1050rpx, rgba(255,255,255,0.7), transparent),
    radial-gradient(2rpx 2rpx at 520rpx 650rpx, rgba(255,255,255,0.8), transparent),
    radial-gradient(1.5rpx 1.5rpx at 350rpx 450rpx, rgba(255,255,255,0.75), transparent);
  background-repeat: repeat;
  background-size: 580rpx 1200rpx;
  animation: twinkle 3s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

.header-section {
  margin-bottom: 40rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-radius: 28rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.4),
    0 2rpx 8rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  margin-right: 28rpx;
  box-shadow: 
    0 0 24rpx rgba(34, 197, 94, 0.5),
    0 8rpx 16rpx rgba(0, 0, 0, 0.3);
  flex-shrink: 0;
  object-fit: cover;
}

.text-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100rpx;
}

.app-name {
  font-size: 50rpx;
  font-weight: 800;
  background: linear-gradient(90deg, #22C55E, #10B981, #34D399, #6EE7B7, #22C55E);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: textShine 4s linear infinite;
  letter-spacing: -1rpx;
  line-height: 1.2;
  margin-bottom: 10rpx;
  filter: drop-shadow(0 0 8rpx rgba(34, 197, 94, 0.4));
}

@keyframes textShine {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}

.slogan {
  font-size: 28rpx;
  font-weight: 500;
  background: linear-gradient(90deg, rgba(255,255,255,0.9), rgba(255,255,255,0.6), rgba(255,255,255,0.9));
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: textShine 4s linear infinite;
  padding-left: 0;
  padding-top: 6rpx;
  letter-spacing: -0.2rpx;
  line-height: 1.4;
  opacity: 0.8;
}

.input-section {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-radius: 28rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.4),
    0 2rpx 8rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 1;
}

.text-input {
  width: 100%;
  min-height: 320rpx;
  font-size: 34rpx;
  line-height: 1.9;
  color: #F8FAFC;
  border: 2rpx solid rgba(34, 197, 94, 0.3);
  border-radius: 20rpx;
  padding: 28rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.6);
  transition: all 0.3s ease;
}

.text-input:focus {
  border-color: #22C55E;
  background: rgba(15, 23, 42, 0.8);
  box-shadow: 
    0 0 0 4rpx rgba(34, 197, 94, 0.2),
    0 0 20rpx rgba(34, 197, 94, 0.15);
  outline: none;
}

.text-input::placeholder {
  color: rgba(248, 250, 252, 0.4);
}

.word-count {
  text-align: right;
  font-size: 28rpx;
  color: rgba(248, 250, 252, 0.5);
  margin-top: 24rpx;
  font-weight: 500;
  letter-spacing: -0.2rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 32rpx;
  letter-spacing: -0.4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.action-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 112rpx;
  line-height: 112rpx;
  border-radius: 28rpx;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: -0.4rpx;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 50%, #15803D 100%);
  color: #FFFFFF;
  border: none;
  box-shadow: 
    0 0 20rpx rgba(34, 197, 94, 0.5),
    0 0 40rpx rgba(34, 197, 94, 0.3),
    0 8rpx 24rpx rgba(34, 197, 94, 0.4),
    0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  animation: neonPulse 2s ease-in-out infinite;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(255,255,255,0.1), transparent);
  transform: rotate(45deg);
  animation: shine 3s ease-in-out infinite;
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

@keyframes neonPulse {
  0%, 100% { 
    box-shadow: 
      0 0 20rpx rgba(34, 197, 94, 0.5),
      0 0 40rpx rgba(34, 197, 94, 0.3),
      0 8rpx 24rpx rgba(34, 197, 94, 0.4);
  }
  50% { 
    box-shadow: 
      0 0 30rpx rgba(34, 197, 94, 0.7),
      0 0 60rpx rgba(34, 197, 94, 0.5),
      0 8rpx 24rpx rgba(34, 197, 94, 0.5);
  }
}

.btn-primary:active {
  background: linear-gradient(135deg, #16A34A 0%, #15803D 50%, #166534 100%);
  transform: scale(0.97) translateY(2rpx);
  animation: none;
  box-shadow: 
    0 0 15rpx rgba(34, 197, 94, 0.4),
    0 0 30rpx rgba(34, 197, 94, 0.3),
    0 4rpx 12rpx rgba(34, 197, 94, 0.4);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  color: #22C55E;
  border: 2rpx solid rgba(34, 197, 94, 0.4);
  box-shadow: 
    0 0 12rpx rgba(34, 197, 94, 0.2),
    0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: rgba(34, 197, 94, 0.15);
  transform: scale(0.97) translateY(2rpx);
  box-shadow: 
    0 0 20rpx rgba(34, 197, 94, 0.3);
}

.history-section {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.4),
    0 2rpx 8rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.toggle-icon {
  font-size: 26rpx;
  color: #22C55E;
  transition: transform 0.3s ease;
  font-weight: 700;
  text-shadow: 0 0 8rpx rgba(34, 197, 94, 0.4);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  padding: 32rpx;
  background: rgba(34, 197, 94, 0.08);
  border-radius: 20rpx;
  transition: all 0.3s ease;
  border: 1px solid rgba(34, 197, 94, 0.15);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.history-item:active {
  background: rgba(34, 197, 94, 0.15);
  transform: scale(0.99);
  box-shadow: 
    0 0 12rpx rgba(34, 197, 94, 0.2);
}

.history-time {
  font-size: 26rpx;
  color: #22C55E;
  margin-bottom: 14rpx;
  font-weight: 600;
  text-shadow: 0 0 6rpx rgba(34, 197, 94, 0.3);
}

.history-content {
  font-size: 30rpx;
  color: rgba(248, 250, 252, 0.9);
  line-height: 1.7;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-weight: 500;
}

.history-empty {
  text-align: center;
  padding: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  color: rgba(248, 250, 252, 0.5);
  font-size: 32rpx;
  font-weight: 600;
}

.btn-clear {
  margin-top: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: rgba(239, 68, 68, 0.15);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  color: #FCA5A5;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  transition: all 0.3s ease;
  box-shadow: 
    0 0 12rpx rgba(239, 68, 68, 0.2);
}

.btn-clear:active {
  background: rgba(239, 68, 68, 0.25);
  transform: scale(0.98);
  box-shadow: 
    0 0 20rpx rgba(239, 68, 68, 0.3);
}