.container {
  padding: 32rpx 28rpx;
  min-height: 100vh;
  background: linear-gradient(-45deg, #0a0a1a 0%, #0f1a2e 25%, #1a2744 50%, #0f1a2e 75%, #0a0a1a 100%);
  background-size: 400% 400%;
  animation: gradientFlow 15s ease infinite;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  position: relative;
  overflow: hidden;
}

@keyframes gradientFlow {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(2.5rpx 2.5rpx at 60rpx 90rpx, rgba(255,255,255,0.95), transparent),
    radial-gradient(1.5rpx 1.5rpx at 180rpx 250rpx, rgba(255,255,255,0.7), transparent),
    radial-gradient(2rpx 2rpx at 320rpx 150rpx, rgba(255,255,255,0.85), transparent),
    radial-gradient(1rpx 1rpx at 450rpx 380rpx, rgba(255,255,255,0.6), transparent),
    radial-gradient(2.5rpx 2.5rpx at 90rpx 520rpx, rgba(255,255,255,0.9), transparent),
    radial-gradient(1rpx 1rpx at 280rpx 600rpx, rgba(255,255,255,0.65), transparent),
    radial-gradient(2rpx 2rpx at 500rpx 200rpx, rgba(255,255,255,0.8), transparent),
    radial-gradient(1.5rpx 1.5rpx at 200rpx 720rpx, rgba(255,255,255,0.75), transparent),
    radial-gradient(2rpx 2rpx at 380rpx 820rpx, rgba(255,255,255,0.9), transparent),
    radial-gradient(1rpx 1rpx at 60rpx 950rpx, rgba(255,255,255,0.55), transparent),
    radial-gradient(2.5rpx 2.5rpx at 160rpx 1100rpx, rgba(255,255,255,0.85), transparent),
    radial-gradient(1rpx 1rpx at 420rpx 1050rpx, rgba(255,255,255,0.7), transparent),
    radial-gradient(2rpx 2rpx at 520rpx 650rpx, rgba(255,255,255,0.8), transparent),
    radial-gradient(1.5rpx 1.5rpx at 350rpx 450rpx, rgba(255,255,255,0.75), transparent),
    radial-gradient(2rpx 2rpx at 100rpx 1150rpx, rgba(255,255,255,0.8), transparent),
    radial-gradient(1rpx 1rpx at 480rpx 1200rpx, rgba(255,255,255,0.65), transparent);
  background-repeat: repeat;
  background-size: 580rpx 1300rpx;
  animation: twinkle 4s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 0.8; }
}

.header-section {
  margin-bottom: 32rpx;
  padding: 36rpx;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
  border-radius: 32rpx;
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.5),
    0 4rpx 12rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 0;
}

.logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  margin-right: 24rpx;
  box-shadow: 
    0 0 24rpx rgba(34, 197, 94, 0.5),
    0 8rpx 20rpx rgba(0, 0, 0, 0.35);
  flex-shrink: 0;
  object-fit: cover;
  border: 2rpx solid rgba(34, 197, 94, 0.3);
}

.text-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 96rpx;
  flex: 1;
}

.app-name {
  font-size: 50rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 3rpx;
  line-height: 1.3;
  margin-bottom: 8rpx;
  text-shadow: 0 0 20rpx rgba(34, 197, 94, 0.4);
}

.app-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1.5rpx;
  line-height: 1.4;
}

.slogan {
  font-size: 28rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 1rpx;
  line-height: 1.5;
  margin-top: 16rpx;
}

.input-section {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
  border-radius: 32rpx;
  padding: 36rpx;
  margin-bottom: 32rpx;
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.5),
    0 4rpx 12rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.06);
  position: relative;
  z-index: 1;
}

.input-label {
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(248, 250, 252, 0.7);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.text-input {
  width: 100%;
  min-height: 280rpx;
  font-size: 32rpx;
  line-height: 1.8;
  color: #F8FAFC;
  border: 2rpx solid rgba(34, 197, 94, 0.25);
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.7);
  transition: all 0.25s ease;
  letter-spacing: 0.5rpx;
}

.text-input:focus {
  border-color: #22C55E;
  background: rgba(15, 23, 42, 0.9);
  box-shadow: 
    0 0 0 4rpx rgba(34, 197, 94, 0.15),
    0 0 16rpx rgba(34, 197, 94, 0.1);
  outline: none;
}

.text-input::placeholder {
  color: rgba(248, 250, 252, 0.35);
  letter-spacing: 0.8rpx;
}

.word-count {
  text-align: right;
  font-size: 26rpx;
  color: rgba(248, 250, 252, 0.45);
  margin-top: 20rpx;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #F8FAFC;
  margin-bottom: 28rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
}

.action-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 108rpx;
  line-height: 108rpx;
  border-radius: 54rpx;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 1rpx;
  transition: all 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.btn-primary {
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 50%, #15803D 100%);
  color: #FFFFFF;
  border: none;
  box-shadow: 
    0 8rpx 32rpx rgba(34, 197, 94, 0.45),
    0 4rpx 16rpx rgba(34, 197, 94, 0.3),
    0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.6s ease;
}

.btn-primary:hover::before {
  left: 100%;
}

.btn-primary:active {
  background: linear-gradient(135deg, #16A34A 0%, #15803D 50%, #166534 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 
    0 4rpx 16rpx rgba(34, 197, 94, 0.4),
    0 2rpx 8rpx rgba(34, 197, 94, 0.25);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  color: #22C55E;
  border: 2rpx solid rgba(34, 197, 94, 0.35);
  box-shadow: 
    0 4rpx 16rpx rgba(34, 197, 94, 0.15),
    0 4rpx 8rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.btn-secondary:hover {
  background: rgba(34, 197, 94, 0.12);
  border-color: rgba(34, 197, 94, 0.5);
  box-shadow: 
    0 6rpx 20rpx rgba(34, 197, 94, 0.25),
    0 4rpx 12rpx rgba(0, 0, 0, 0.25);
}

.btn-secondary:active {
  background: rgba(34, 197, 94, 0.18);
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 
    0 2rpx 8rpx rgba(34, 197, 94, 0.3);
}

.history-section {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
  border-radius: 32rpx;
  padding: 36rpx;
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.5),
    0 4rpx 12rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.06);
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(34, 197, 94, 0.15);
}

.toggle-icon {
  font-size: 24rpx;
  color: #22C55E;
  transition: transform 0.3s ease;
  font-weight: 700;
  text-shadow: 0 0 8rpx rgba(34, 197, 94, 0.4);
  padding: 8rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.history-item {
  padding: 28rpx;
  background: rgba(34, 197, 94, 0.07);
  border-radius: 22rpx;
  transition: all 0.25s ease;
  border: 1rpx solid rgba(34, 197, 94, 0.12);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.history-item:active {
  background: rgba(34, 197, 94, 0.14);
  transform: scale(0.985);
  box-shadow: 
    0 0 12rpx rgba(34, 197, 94, 0.2);
}

.history-time {
  font-size: 26rpx;
  color: #22C55E;
  margin-bottom: 12rpx;
  font-weight: 500;
  text-shadow: 0 0 6rpx rgba(34, 197, 94, 0.3);
  letter-spacing: 0.5rpx;
}

.history-content {
  font-size: 30rpx;
  color: rgba(248, 250, 252, 0.88);
  line-height: 1.7;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.history-empty {
  text-align: center;
  padding: 72rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 22rpx;
  color: rgba(248, 250, 252, 0.45);
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.btn-clear {
  margin-top: 24rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: rgba(239, 68, 68, 0.12);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  color: #FCA5A5;
  border: 1rpx solid rgba(239, 68, 68, 0.25);
  transition: all 0.25s ease;
  box-shadow: 
    0 4rpx 12rpx rgba(239, 68, 68, 0.15);
  letter-spacing: 0.8rpx;
}

.btn-clear:active {
  background: rgba(239, 68, 68, 0.22);
  transform: scale(0.97);
  box-shadow: 
    0 2rpx 8rpx rgba(239, 68, 68, 0.25);
}